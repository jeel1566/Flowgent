# LLM Configuration
# Use "litellm/openrouter/deepseek/deepseek-chat" for free OpenRouter models (recommended)
# Use "gemini-2.0-flash" for Google Gemini (needs GOOGLE_GENAI_API_KEY)
LLM_MODEL=litellm/openrouter/deepseek/deepseek-chat

# OpenRouter (free! Get key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Google Gemini (optional, for Gemini models)
# GOOGLE_GENAI_API_KEY=your-gemini-key-here

# Fallback Model (optional, used when primary model hits rate limits)
# FALLBACK_LLM_MODEL=azure/gpt-5.2
# FALLBACK_AZURE_API_KEY=your-fallback-api-key
# FALLBACK_AZURE_API_BASE=https://your-endpoint.cognitiveservices.azure.com/openai/deployments/gpt-5.2/chat/completions?api-version=2025-04-01-preview

# n8n MCP Configuration
N8N_MCP_URL=https://api.n8n-mcp.com/mcp
N8N_MCP_API_KEY=your-n8n-mcp-api-key

# Server
PORT=8000
HOST=0.0.0.0
ALLOWED_ORIGINS=*
